{
  "name": "meridian-ui",
  "type": "module",
  "version": "1.0.1",
  "description": "A React component library for building malleable overview-detail interfaces with the Meridian design framework",
  "keywords": [
    "react",
    "components",
    "overview-detail",
    "data-visualization",
    "ui-library",
    "meridian",
    "interface-design"
  ],
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/esm/dist/meridian.css"
  },
  "scripts": {
    "build": "rollup -c",
    "test": "vitest",
    "watch": "rollup -c -w",
    "test:run": "vitest run",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix"
  },
  "peerDependencies": {
    "@vis.gl/react-google-maps": "^1.x.x",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "interactjs": "^1.10.27",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/node": "^24.7.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vis.gl/react-google-maps": "^1.6.0",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.4.7",
    "eslint": "^9.38.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.24.0",
    "rollup-plugin-dts": "^6.2.3",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.93.2",
    "storybook": "^8.3.5",
    "tailwindcss": "^4.1.16",
    "ts-loader": "^9.5.1",
    "tslib": "^2.7.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "sideEffects": ["*.css"]
}
